{
  "name": "osml-demo",
  "version": "1.0.0",
  "license": "UNLICENSED",
  "bin": {
    "osml": "bin/app.ts"
  },
  "scripts": {
    "build": "tsc",
    "synth": "cdk synth",
    "deploy": "cdk deploy --all --require-approval never --concurrency 10 || exit 1",
    "destroy": "bash scripts/dev_destroy.sh || exit 1",
    "clean": "bash scripts/dev_clean.sh",
    "lint": "pre-commit run --all-files",
    "watch": "tsc -w",
    "prepare": "npm run-script build",
    "integ:model-runner": "bash scripts/model_runner_integ.sh",
    "integ:tile-server": "bash scripts/tile_server_integ.sh"
  },
  "dependencies": {
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@aws-sdk/client-iam": "^3.864.0",
    "@cdklabs/cdk-enterprise-iac": "^0.1.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.2.1",
    "@types/source-map-support": "^0.5.10",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "aws-cdk": "^2.1024.0",
    "aws-cdk-lib": "^2.210.0",
    "cdk-nag": "^2.37.1",
    "constructs": "^10.4.2",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.0.1",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jest": "^30.0.5",
    "lint-staged": "^16.1.5",
    "osml-cdk-constructs": "^2.1.0",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.1",
    "typescript": "^5.9.2"
  },
  "browser": {
    "child_process": false
  }
}
