{
  "name": "osml-guidance",
  "version": "1.0.0",
  "license": "MIT No Attribution",
  "scripts": {
    "build": "tsc --noEmit",
    "test": "jest --config jest.config.ts",
    "test:root": "jest --config jest.config.ts --roots '<rootDir>/test'",
    "test:osml-vpc": "jest --config jest.config.ts --roots '<rootDir>/lib/osml-vpc/cdk/test'",
    "test:osml-apis": "jest --config jest.config.ts --roots '<rootDir>/lib/osml-apis/cdk/test'",
    "deploy": "bash scripts/deploy.sh",
    "destroy": "bash scripts/destroy.sh",
    "clean": "bash scripts/dev_clean.sh",
    "lint": "pre-commit run --all-files",
    "watch": "tsc -w",
    "integ:model-runner": "cd lib/osml-model-runner && python bin/run-integration-tests.py --suite test/integ/suites/default.json",
    "integ:tile-server": "bash lib/osml-tile-server/scripts/tile_server_integ.sh",
    "integ:data-intake": "cd lib/osml-data-intake && pytest -m integration test/integ/test_integration.py -s",
    "integ:geo-agents": "bash lib/osml-geo-agents/scripts/geo_agents_integ.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.1.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "fast-check": "^4.4.0",
    "globals": "^15.14.0",
    "jest": "^30.2.0",
    "lint-staged": "^15.2.7",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  }
}
